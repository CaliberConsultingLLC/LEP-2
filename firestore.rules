rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwnerUid(uid) {
      return isSignedIn() && uid is string && uid == request.auth.uid;
    }

    match /responses/{docId} {
      allow create, get, update: if isOwnerUid(docId);
      allow list, delete: if false;
    }

    match /societalNorms/{docId} {
      allow create, get, update: if isSignedIn();
      allow list, delete: if false;
    }

    match /campaigns/{docId} {
      allow create, update: if isSignedIn();
      allow get: if isSignedIn();
      allow list, delete: if false;
    }

    match /surveyResponses/{docId} {
      allow create: if isSignedIn();
      allow get, update: if isSignedIn();
      allow list: if isSignedIn();
      allow delete: if false;
    }

    match /users/{docId} {
      allow create, get, update: if isSignedIn();
      allow list, delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
