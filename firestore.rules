rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwnerUid(uid) {
      return isSignedIn() && uid is string && uid == request.auth.uid;
    }

    match /responses/{docId} {
      allow create: if isOwnerUid(docId)
        && request.resource.data.ownerUid is string
        && request.resource.data.ownerUid == request.auth.uid;
      allow get, update: if isOwnerUid(docId)
        && resource.data.ownerUid is string
        && resource.data.ownerUid == request.auth.uid;
      allow list, delete: if false;
    }

    match /societalNorms/{docId} {
      allow create, get, update: if isSignedIn();
      allow list, delete: if false;
    }

    match /campaigns/{docId} {
      allow create: if (
        (request.resource.data.ownerUid is string && request.resource.data.ownerUid == request.auth.uid)
        || (request.resource.data.userInfo.uid is string && request.resource.data.userInfo.uid == request.auth.uid)
      );
      allow get, update: if (
        (resource.data.ownerUid is string && resource.data.ownerUid == request.auth.uid)
        || (resource.data.userInfo.uid is string && resource.data.userInfo.uid == request.auth.uid)
      );
      allow list, delete: if false;
    }

    match /surveyResponses/{docId} {
      allow create: if isSignedIn()
        && request.resource.data.ownerUid is string
        && request.resource.data.ownerUid == request.auth.uid;
      allow get, list: if isSignedIn()
        && resource.data.ownerUid is string
        && resource.data.ownerUid == request.auth.uid;
      allow update, delete: if false;
    }

    match /users/{docId} {
      allow create: if request.resource.data.uid is string
        && request.resource.data.uid == request.auth.uid;
      allow get, update: if resource.data.uid is string
        && resource.data.uid == request.auth.uid;
      allow list, delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
